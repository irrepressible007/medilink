// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(auto()) @map("_id") @db.ObjectId
  fullName         String
  email            String            @unique
  passwordHash     String
  phone            String?
  role             String            @default("patient")
  specialty        String?           // Used for classifying doctors
  dateOfBirth      String?
  bloodGroup       String?
  allergies        String?
  emergencyContact String?
  avatarUrl        String?
  createdAt        DateTime          @default(now())
  appointments     Appointment[]
  followUpRequests FollowUpRequest[]
  prescriptions    Prescription[]
  notifications    Notification[]
  medicalRecords   MedicalRecord[]
}

model Appointment {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  patientName     String
  dateOfBirth     String
  gender          String
  contactNumber   String
  email           String
  requestFor      String?
  doctorOrService String?
  appointmentDate String
  appointmentTime String
  status          String   @default("pending")
  notes           String?
  reminderSent    Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])

  followUpRequests FollowUpRequest[]
  prescriptions    Prescription[]
  notifications    Notification[]
  medicalRecords   MedicalRecord[]
}

model FollowUpRequest {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  reason        String
  preferredDate String?
  preferredTime String?
  status        String   @default("pending")
  createdAt     DateTime @default(now())

  appointmentId String      @db.ObjectId
  appointment   Appointment @relation(fields: [appointmentId], references: [id])

  patientId String @db.ObjectId
  patient   User   @relation(fields: [patientId], references: [id])
}

model Prescription {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  medicationName String
  dosage         String
  frequency      String
  alertTimes     String[]
  startDate      String
  endDate        String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())

  appointmentId String      @db.ObjectId
  appointment   Appointment @relation(fields: [appointmentId], references: [id])

  patientId String @db.ObjectId
  patient   User   @relation(fields: [patientId], references: [id])
}

model Notification {
  id      String   @id @default(auto()) @map("_id") @db.ObjectId
  type    String
  channel String
  subject String
  body    String
  sentAt  DateTime @default(now())
  success Boolean  @default(true)
  errorMsg String?

  appointmentId String?      @db.ObjectId
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])
}

model MedicalRecord {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  title         String
  description   String?
  recordType    String   // e.g., "lab_result", "doctor_note", "xray"
  fileUrl       String?  // Cloudinary/AWS URL
  createdAt     DateTime @default(now())

  patientId     String   @db.ObjectId
  patient       User     @relation(fields: [patientId], references: [id])

  appointmentId String?      @db.ObjectId
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
}

model Conversation {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  patientId    String    @db.ObjectId
  doctorId     String    @db.ObjectId
  updatedAt    DateTime  @updatedAt
  createdAt    DateTime  @default(now())

  messages     Message[]
}

model Message {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  content        String
  senderId       String       @db.ObjectId
  conversationId String       @db.ObjectId
  hasAttachment  Boolean      @default(false)
  fileUrl        String?
  createdAt      DateTime     @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model EmergencyRequest {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  latitude    Float
  longitude   Float
  status      String   @default("pending") // pending, dispatched, resolved
  createdAt   DateTime @default(now())
  
  userId      String   @db.ObjectId
}

model Referral {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  referringDocId   String   @db.ObjectId
  referredToDocId  String   @db.ObjectId
  patientId        String   @db.ObjectId
  notes            String
  createdAt        DateTime @default(now())
}

model BloodDonor {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  fullName    String
  bloodGroup  String
  phone       String
  city        String
  lastDonated DateTime?
  createdAt   DateTime @default(now())
}

model BloodRequest {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  patientName   String
  bloodGroup    String
  hospital      String
  city          String
  phone         String
  urgency       String   @default("regular") // regular, urgent, emergency
  status        String   @default("open")
  createdAt     DateTime @default(now())
}
